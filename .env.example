# IAHE DPR Reviewer — Environment Variables
# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.

# ─────────────────────────────────────────────────────────
# Tier 1 — Code & Standard Lookup (Priority: configure first)
# ─────────────────────────────────────────────────────────

# IRC Digital Library API
IRC_API_KEY=
IRC_API_BASE_URL=https://api.irc.org.in/v1

# MoRTH Specifications Database
MORTH_API_KEY=
MORTH_API_BASE_URL=https://morth.nic.in/api/specs/v1

# BIS Standards Portal
BIS_API_KEY=
BIS_API_BASE_URL=https://bis.gov.in/api/standards/v1

# NHAI Circular Repository
NHAI_API_KEY=
NHAI_API_BASE_URL=https://nhai.gov.in/api/circulars/v1

# ─────────────────────────────────────────────────────────
# Tier 2 — Project Data Connectors
# ─────────────────────────────────────────────────────────

# Google Drive (OAuth 2.0)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# SharePoint / OneDrive (Azure AD App Registration)
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=

# Autodesk Docs / AutoCAD Web (APS)
AUTODESK_CLIENT_ID=
AUTODESK_CLIENT_SECRET=

# Excel / Local file path (optional default)
EXCEL_FILE_PATH=

# ─────────────────────────────────────────────────────────
# Tier 3 — Engineering Software
# ─────────────────────────────────────────────────────────

# HEC-RAS / HEC-HMS output directory
HECRAS_PROJECT_DIR=
HECHMS_PROJECT_DIR=

# IITPAVE / KENPAVE output directory
IITPAVE_OUTPUT_DIR=

# ─────────────────────────────────────────────────────────
# Tier 4 — Government Portals
# ─────────────────────────────────────────────────────────

# Indian Meteorological Department
IMD_API_KEY=
IMD_API_BASE_URL=https://api.imd.gov.in/v1

# PARIVESH Environmental Clearance Portal
PARIVESH_API_KEY=
PARIVESH_BASE_URL=https://parivesh.nic.in/api/v1

# ─────────────────────────────────────────────────────────
# Tier 5 — Productivity
# ─────────────────────────────────────────────────────────

# Slack Bot Integration
SLACK_BOT_TOKEN=xoxb-
SLACK_DEFAULT_CHANNEL=#dpr-reviews

# Primavera P6 / MS Project
PRIMAVERA_DB_URL=
MSPROJECT_FILE_PATH=
